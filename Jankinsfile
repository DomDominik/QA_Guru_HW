pipeline {
    agent any

    parameters {
        choice(
            name: 'BROWSER',
            choices: ['chrome', 'firefox', 'edge'],
            description: 'Выберите браузер для тестов'
        )

        string(
            name: 'BROWSER_VERSION',
            defaultValue: '128',
            description: 'Версия браузера (например: 128, 120, latest)'
        )

        choice(
            name: 'RESOLUTION',
            choices: ['1920x1080', '1366x768', '1280x720'],
            description: 'Разрешение экрана'
        )

        booleanParam(
            name: 'HEADLESS',
            defaultValue: false,
            description: 'Запуск в headless режиме'
        )

        string(
            name: 'BASE_URL',
            defaultValue: 'https://demoqa.com',
            description: 'Адрес тестируемого сайта'
        )

        string(
            name: 'REMOTE_URL',
            defaultValue: '',
            description: 'Адрес Selenoid (оставьте пустым для локального запуска)'
        )

        choice(
            name: 'GROUPS',
            choices: ['Smoke', 'Web', 'All'],
            description: 'Группы тестов для запуска'
        )
    }

    environment {
        // Переменные окружения для отчета
        ALLURE_RESULTS = 'build/allure-results'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Код склонирован из репозитория"
            }
        }

        stage('Setup Java') {
            steps {
                // Убедитесь, что Java установлена
                sh 'java -version'
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    // Формируем аргументы для Gradle
                    def gradleArgs = []

                    // Добавляем параметры только если они не пустые
                    gradleArgs.add("-Dbrowser=${params.BROWSER}")
                    gradleArgs.add("-Dbrowser.version=${params.BROWSER_VERSION}")
                    gradleArgs.add("-Dresolution=${params.RESOLUTION}")
                    gradleArgs.add("-Dheadless=${params.HEADLESS}")
                    gradleArgs.add("-Dbase.url=${params.BASE_URL}")

                    if (params.REMOTE_URL?.trim()) {
                        gradleArgs.add("-Dremote.url=${params.REMOTE_URL}")
                    }

                    if (params.GROUPS != 'All') {
                        gradleArgs.add("-Dgroups=${params.GROUPS}")
                    }

                    // Выводим команду для отладки
                    echo "Запуск: ./gradlew test ${gradleArgs.join(' ')}"

                    // Запускаем тесты
                    sh "./gradlew clean test ${gradleArgs.join(' ')}"
                }
            }
        }

        stage('Generate Allure Report') {
            steps {
                script {
                    // Проверяем, есть ли результаты тестов
                    if (fileExists('build/allure-results')) {
                        allure([
                            includeProperties: false,
                            jdk: '',
                            properties: [],
                            reportBuildPolicy: 'ALWAYS',
                            results: [[path: 'build/allure-results']]
                        ])
                    } else {
                        echo "Allure results not found"
                    }
                }
            }
        }
    }

    post {
        always {
            // Публикуем JUnit отчет
            junit 'build/test-results/test/*.xml'

            // Публикуем HTML отчет
            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'build/reports/tests/test',
                reportFiles: 'index.html',
                reportName: 'JUnit Test Report'
            ])

            echo "Тесты завершены. Статус: ${currentBuild.currentResult}"
        }

        success {
            echo "✅ Все тесты прошли успешно!"
        }

        failure {
            echo "❌ Некоторые тесты упали. Проверьте отчеты."
        }
    }
}